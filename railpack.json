{
  "build": {
    "cmds": [
      "pnpm install --no-frozen-lockfile --filter @workspace/db --filter @workspace/api-zod --filter @workspace/api-server",
      "node artifacts/api-server/build.mjs"
    ]
  },
  "start": {
    "cmd": "node --enable-source-maps artifacts/api-server/dist/index.mjs"
  }
}
